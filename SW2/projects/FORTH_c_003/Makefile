MAKEFLAGS += --no-print-directory --no-builtin-rules
ROOT_DIR := $(abspath ../..)
MK_DEP += linker.ld
include config.mk
include $(ROOT_DIR)/mk/libs.mk
include $(ROOT_DIR)/mk/rules.mk

# Recipe R_need_target_update {{{
R_need_target_update = \
	if cmp -s $@ $@.tmp &>/dev/null ; then \
		rm -f $@.tmp; \
		echo -e "$(COLORS)$(BRIGHTYELLOW);$(BG_GREEN)m$@$(COLORS)$(RESET)m - is OK"; \
	else \
		mv $@.tmp $@; \
		echo -e "$(COLORS)$(BRIGHTCYAN);$(BG_BLUE)m$@$(COLORS)$(RESET)m - updated"; \
	fi
# }}}

INC_FILES := $(wildcard src/words/*/*)


$(CURDIR)/src/TCB_offsets.inc: $(CURDIR)/src/TCB_offsets.func Makefile
	$(HEAD)
	$(Q)$(CC) -x c $(CFLAGS_NODEP)  -S $< -o src/TCB_offsets.tmp
	$(Q)grep "\.equ" src/TCB_offsets.tmp >$@
	$(Q)rm src/TCB_offsets.tmp




$(CURDIR)/src/words/all_words.S: $(INC_FILES) $(CURDIR)/src/TCB_offsets.inc FORCE
	$(HEAD)
	$(Q)echo -e "; DO NOT EDIT\n; Autogenerated file\n" >$@.tmp
	$(Q)echo "#include \"../version.h\"" >> $@.tmp;
	$(Q)for f in $(INC_FILES); do \
		echo "#include \"../../$$f\"" >> $@.tmp; \
	done
	$(Q)$(R_need_target_update)

